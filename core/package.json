  },
  "dependencies": {
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0"
  }
}
