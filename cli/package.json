{
  "name": "@arsh342/athena",
  "version": "0.2.1",
  "description": "AI code provenance tracker and terminal scanner for JavaScript and TypeScript repositories.",
  "type": "module",
  "bin": {
    "athena": "dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "null-pointer-font"
  ],
  "keywords": [
    "ai",
    "code-review",
    "security",
    "static-analysis",
    "cli",
    "typescript",
    "provenance"
  ],
  "author": "Arshdeep Singh",
  "license": "MIT",
  "homepage": "https://github.com/arsh342/athena#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arsh342/athena.git"
  },
  "bugs": {
    "url": "https://github.com/arsh342/athena/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0"
  },
  "devDependencies": {
    "@athena/core": "file:../core",
    "commander": "^14.0.0",
    "tsx": "^4.19.0"
  }
}
